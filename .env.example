# ============================================================================
# MarsTV 环境变量示例 / Copy to `.env.local` (apps/web) and fill in real values
# ============================================================================

# ---- 代理鉴权(必填) ----
# 用于 /api/proxy/* 的 HMAC 签名,未设置时服务将拒绝启动
PROXY_SECRET=change_me_to_a_long_random_string

# ---- 可选:前端访问密码 ----
# 设置后用户首次访问需输入密码,留空则不启用
SITE_PASSWORD=

# ---- 存储后端(三选一) ----
# 不填 = 仅本地 localStorage / IndexedDB(无云同步)
#
# 模式 A: Upstash Redis(推荐 Serverless 场景)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
#
# 模式 B: 自托管 Redis / Kvrocks(推荐 Docker 场景)
# REDIS_URL=redis://localhost:6379

# ---- Web Push(追剧订阅需要) ----
# 使用 `npx web-push generate-vapid-keys` 生成
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# ---- 豆瓣代理模式 ----
# direct | tencent | aliyun | custom
DOUBAN_PROXY_MODE=direct
DOUBAN_CUSTOM_PROXY=

# ---- 站点基础配置 ----
NEXT_PUBLIC_SITE_NAME=MarsTV
NEXT_PUBLIC_SITE_URL=http://localhost:3000
