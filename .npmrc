# MarsTV — pnpm workspace config
# node-linker=hoisted avoids NTFS junctions / hard-links, which are
# unreliable on NAS-backed F: drive. Trade-off: a flatter, heavier
# node_modules; workspace package resolution still works through pnpm.
node-linker=hoisted

# Keep strict resolution so hoisted layout doesn't leak phantom deps.
strict-peer-dependencies=false
auto-install-peers=true
