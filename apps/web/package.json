{
  "name": "@marstv/web",
  "version": "260502a",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test && playwright test --config playwright.site-password.config.ts",
    "test:e2e:site-password": "playwright test --config playwright.site-password.config.ts",
    "test:e2e:ui": "playwright test --ui",
    "build:cf": "opennextjs-cloudflare build",
    "preview:cf": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy:cf": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "build:docker": "docker build -f apps/web/Dockerfile -t marstv/web:local ../..",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@marstv/config": "workspace:*",
    "@marstv/core": "workspace:*",
    "@marstv/ui-web": "workspace:*",
    "@radix-ui/react-slot": "catalog:",
    "@tauri-apps/api": "catalog:",
    "artplayer": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "hls.js": "catalog:",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwind-merge": "catalog:"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "catalog:",
    "@playwright/test": "catalog:",
    "@tailwindcss/postcss": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite-tsconfig-paths": "catalog:",
    "vitest": "catalog:",
    "wrangler": "catalog:"
  }
}
