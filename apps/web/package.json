{
  "name": "@marstv/web",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test && playwright test --config playwright.site-password.config.ts",
    "test:e2e:site-password": "playwright test --config playwright.site-password.config.ts",
    "test:e2e:ui": "playwright test --ui",
    "build:cf": "next build && opennextjs-cloudflare build",
    "preview:cf": "next build && opennextjs-cloudflare preview",
    "deploy:cf": "next build && opennextjs-cloudflare deploy",
    "build:docker": "docker build -f apps/web/Dockerfile -t marstv/web:local ../.."
  },
  "dependencies": {
    "@marstv/config": "workspace:*",
    "@marstv/core": "workspace:*",
    "@marstv/ui-web": "workspace:*",
    "@radix-ui/react-slot": "catalog:",
    "@tauri-apps/api": "^2.10.1",
    "artplayer": "^5.2.4",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "hls.js": "^1.6.15",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwind-merge": "catalog:"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "catalog:",
    "wrangler": "^4.86.0"
  }
}
