{
  "$schema": "../../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MarsTV",
  "version": "0.1.0",
  "identifier": "com.marstv.app",
  "build": {
    "frontendDist": "../web/out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm --filter @marstv/web dev",
    "beforeBuildCommand": "TAURI_BUILD=1 pnpm --filter @marstv/web build"
  },
  "app": {
    "windows": [
      {
        "title": "MarsTV",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
