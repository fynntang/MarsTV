{
  "name": "marstv",
  "version": "0.0.0",
  "private": true,
  "description": "A faster, better-looking, cross-platform open-source video aggregation platform.",
  "license": "MIT",
  "author": "Fynn Tang <fzpying@gmail.com>",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @marstv/web dev",
    "build": "pnpm -r build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "clean": "pnpm -r exec rm -rf node_modules .next dist .turbo",
    "catalog": "pnpx codemod pnpm/catalog"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "typescript": "catalog:"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "sharp"]
  }
}
